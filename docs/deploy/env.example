# /etc/9router-mw/env — mode 0640 root:router
# Copy secrets on VPS only. NEVER commit real values.

PORT=20128
HOSTNAME=127.0.0.1
HOST=127.0.0.1
WORKERS=4
NODE_ENV=production
DATA_DIR=/var/lib/9router-mw
NEXT_TELEMETRY_DISABLED=1

# DNS IPv4-first for undici/upstream
NODE_OPTIONS=--dns-result-order=ipv4first

# Logging (D22)
LOG_LEVEL=warn
ENABLE_REQUEST_LOGS=false

# Redis dedicated 6381 (password set on VPS only)
REDIS_HOST=127.0.0.1
REDIS_PORT=6381
# REDIS_PASSWORD=...
# REDIS_URL=redis://:PASSWORD@127.0.0.1:6381/0

# Dashboard auth
JWT_SECRET=change-me-openssl-rand-hex-32
INITIAL_PASSWORD=change-me-openssl-rand-base64-24
AUTH_COOKIE_SECURE=false

# Optional salts (stable defaults OK for baseline)
API_KEY_SECRET=endpoint-proxy-api-key-secret
MACHINE_ID_SALT=endpoint-proxy-salt

# Do NOT set: MITM_SERVER_PATH, MITM_ROUTER_BASE
