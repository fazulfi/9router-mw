# /etc/9router-mw/env — mode 0640 root:router
# Copy secrets on VPS only. NEVER commit real values.

PORT=20128
HOSTNAME=127.0.0.1
HOST=127.0.0.1
WORKERS=4
NODE_ENV=production
DATA_DIR=/var/lib/9router-mw
NEXT_TELEMETRY_DISABLED=1

# DNS IPv4-first for undici/upstream
NODE_OPTIONS=--dns-result-order=ipv4first

# Logging (D22)
LOG_LEVEL=warn
ENABLE_REQUEST_LOGS=false

# F6: ban sql.js in prod multi-worker (default on when NODE_ENV=production)
MW_REQUIRE_NATIVE_SQLITE=1

# F6 undici Agent (optional overrides; defaults match plan §3.5)
# MW_UNDICI_CONNECTIONS=32
# MW_UNDICI_PIPELINING=1
# MW_UNDICI_KEEPALIVE_MS=30000
# MW_UNDICI_KEEPALIVE_MAX_MS=60000

# Redis dedicated 6381 (password set on VPS only — never 6379/6380)
REDIS_HOST=127.0.0.1
REDIS_PORT=6381
# REDIS_PASSWORD=...
# REDIS_URL=redis://:PASSWORD@127.0.0.1:6381/0

# Multi-worker shared state (Fase 4)
# MW_SEM_MAX=1
# MW_SEM_TTL_SEC=120
# MW_CB_FAILURE_THRESHOLD=5
# MW_CB_SUCCESS_THRESHOLD=2
# MW_CB_OPEN_MS=30000
# MW_USAGE_FLUSH_MS=2000

# Settings memory cache TTL ms (Fase 5, default 5000)
# MW_SETTINGS_CACHE_MS=5000


# Dashboard auth
JWT_SECRET=change-me-openssl-rand-hex-32
INITIAL_PASSWORD=change-me-openssl-rand-base64-24
AUTH_COOKIE_SECURE=false

# Optional salts (stable defaults OK for baseline)
API_KEY_SECRET=endpoint-proxy-api-key-secret
MACHINE_ID_SALT=endpoint-proxy-salt

# Do NOT set: MITM_SERVER_PATH, MITM_ROUTER_BASE
